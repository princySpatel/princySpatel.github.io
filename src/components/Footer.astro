---
import { getConfigurationCollection } from "../lib/utils";
import Anchor from "./common/Anchor.astro";
import Section from "./common/Section.astro";

const { data: config } = await getConfigurationCollection();

const date = new Date();
const year = date.getFullYear();
---

<footer class="mt-16 mb-8">
  <Section class="mb-4">
    <div class="zag-border-b zag-transition pb-6 flex flex-col sm:flex-row justify-between gap-8 sm:items-end">
      
      <ul class="flex flex-col gap-2 font-mono">
        {
          Object.entries(config.menu).map((i) => (
            <li>
              <Anchor url={i[1]}>{i[0]}</Anchor>
            </li>
          ))
        }
      </ul>

      <div class="flex flex-col items-start sm:items-end gap-3 w-full sm:w-auto">
        <h3 class="text-base font-bold font-pixel zag-text">Connect with me</h3>
        
        <div class="flex flex-row gap-4">
          {
            config.personal.email && (
              <Anchor url={config.personal.email} aria-label="Email Me">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24">
                  <title>Email</title>
                  <path class="zag-fill zag-transition" d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                </svg>
              </Anchor>
            )
          }

          {
            config.personal.leetcodeProfile && (
              <Anchor url={config.personal.leetcodeProfile} aria-label={`${config.personal.name} LeetCode Profile`}>
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24">
                  <title>LeetCode</title>
                  <path class="zag-fill zag-transition" d="M16.102 17.93l-2.697 2.607c-.466.467-1.111.662-1.823.662s-1.357-.195-1.824-.662l-4.332-4.363c-.467-.467-.702-1.15-.702-1.863s.235-1.357.702-1.824l4.319-4.38c.467-.467 1.125-.645 1.837-.645s1.357.195 1.823.662l2.697 2.606c.514.515 1.365.497 1.9-.038.536-.536.554-1.387.039-1.901l-2.609-2.636a5.055 5.055 0 0 0-3.588-1.319c-1.372 0-2.688.476-3.658 1.447l-4.32 4.38c-.97.97-1.447 2.25-1.447 3.588s.477 2.65 1.447 3.62l4.332 4.363c.97.97 2.286 1.447 3.658 1.447s2.688-.477 3.658-1.447l2.609-2.636c.515-.514.497-1.365-.039-1.901-.536-.535-1.387-.517-1.901-.038zM20.811 11.283c-1.144-.06-1.846-.098-2.348-.124-.462-.023-.668-.344-.654-.755.01-.26.046-.532.096-.807.085-.472.482-.693 1.084-.693.425 0 1.258.04 2.127.084.532.027 1.042.441 1.059.94.02 1.025-.262 1.439-1.364 1.355z"/>
                </svg>
              </Anchor>
            )
          }

          {
            config.personal.githubProfile && (
              <Anchor url={config.personal.githubProfile} aria-label={`${config.personal.name} GitHub Profile`}>
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24">
                  <title>GitHub</title>
                  <path class="zag-fill zag-transition" d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.1-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.1 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2"/>
                </svg>
              </Anchor>
            )
          }

          {
            config.personal.linkedinProfile && (
              <Anchor url={config.personal.linkedinProfile} aria-label={`${config.personal.name} LinkedIn Profile`}>
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24">
                  <title>LinkedIn</title>
                  <path class="zag-fill zag-transition" fill="currentColor" d="M19 0h-14c-2.76 0-5 2.24-5 5v14c0 2.76 2.24 5 5 5h14c2.76 0 5-2.24 5-5v-14c0-2.76-2.24-5-5-5zm-11.12 19h-3.08v-9h3.08v9zm-1.54-10.29c-.99 0-1.79-.8-1.79-1.79s.8-1.79 1.79-1.79 1.79.8 1.79 1.79-.8 1.79-1.79 1.79zm13.16 10.29h-3.08v-4.89c0-1.16-.02-2.64-1.61-2.64s-1.86 1.26-1.86 2.57v4.96h-3.08v-9h2.96v1.23h.04c.41-.78 1.4-1.6 2.88-1.6 3.08 0 3.65 2.03 3.65 4.66v4.71z"/>
                </svg>
              </Anchor>
            )
          }
        </div>
      </div>
    </div>
  </Section>
  
  <p class="zag-text zag-transition text-center text-sm font-medium font-mono">
    &copy; {year} {config.personal.name}. All rights reserved.
  </p>
</footer>